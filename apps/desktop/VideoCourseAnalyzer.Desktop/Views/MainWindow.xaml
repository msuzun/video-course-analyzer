<Window x:Class="VideoCourseAnalyzer.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Video Course Analyzer"
        Width="1400"
        Height="850"
        MinWidth="1000"
        MinHeight="650">
  <Grid Margin="12">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="2*" />
      <ColumnDefinition Width="5*" />
      <ColumnDefinition Width="3*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0" Margin="0,0,10,0" Padding="10" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Library" />
        <ListBox Grid.Row="1"
                 Margin="0,10,0,0"
                 ItemsSource="{Binding Jobs}"
                 SelectedItem="{Binding SelectedJob}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="{Binding JobId}" />
                <TextBlock Opacity="0.7" Text="{Binding Status}" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>

    <Border Grid.Column="1" Margin="0,0,10,0" Padding="10" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Chat" />
        <ListBox Grid.Row="1"
                 Margin="0,10,0,10"
                 ItemsSource="{Binding ChatMessages}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Margin="0,0,0,8">
                <TextBlock FontWeight="SemiBold" Text="{Binding Role}" />
                <TextBlock TextWrapping="Wrap" Text="{Binding Content}" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
        <DockPanel Grid.Row="2">
          <TextBox Height="34" VerticalContentAlignment="Center" Text="Mesaj yaz..." Foreground="#777777" />
        </DockPanel>
      </Grid>
    </Border>

    <Border Grid.Column="2" Padding="10" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Sources" />
        <ListBox Grid.Row="1" Margin="0,10,0,0" ItemsSource="{Binding Sources}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Margin="0,0,0,10">
                <TextBlock FontWeight="SemiBold" Text="{Binding ChunkId}" />
                <TextBlock Opacity="0.7" Text="{Binding Snippet}" TextWrapping="Wrap" />
                <TextBlock Opacity="0.6" Text="{Binding T0, StringFormat=t0: {0:F1}}" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>
  </Grid>
</Window>
