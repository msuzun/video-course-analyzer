<Window x:Class="VideoCourseAnalyzer.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Video Course Analyzer"
        Width="1400"
        Height="850"
        MinWidth="1000"
        MinHeight="650">
  <Grid Margin="12">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="2*" />
      <ColumnDefinition Width="5*" />
      <ColumnDefinition Width="3*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0" Margin="0,0,10,0" Padding="10" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Library" />
        <StackPanel Grid.Row="1" Margin="0,10,0,10">
          <TextBlock FontWeight="SemiBold" Text="New Analysis" />
          <DockPanel Margin="0,6,0,0">
            <Button Width="80"
                    Height="30"
                    Margin="8,0,0,0"
                    Content="Start"
                    Command="{Binding StartAnalysisCommand}"
                    DockPanel.Dock="Right" />
            <TextBox Height="30"
                     VerticalContentAlignment="Center"
                     Text="{Binding NewAnalysisUrl, UpdateSourceTrigger=PropertyChanged}" />
          </DockPanel>
        </StackPanel>
        <ListBox Grid.Row="2"
                 Margin="0,10,0,0"
                 ItemsSource="{Binding Jobs}"
                 SelectedItem="{Binding SelectedJob}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="{Binding JobId}" />
                <TextBlock Opacity="0.7" Text="{Binding Status}" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>

    <Border Grid.Column="1" Margin="0,0,10,0" Padding="10" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="3*" />
          <RowDefinition Height="2*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Analysis Monitor" />
        <ProgressBar Grid.Row="1" Height="18" Margin="0,10,0,0" Minimum="0" Maximum="100" Value="{Binding ProgressValue}" />
        <DockPanel Grid.Row="2" Margin="0,8,0,0">
          <TextBlock FontWeight="SemiBold" Text="Status:" />
          <TextBlock Margin="6,0,12,0" Text="{Binding CurrentStatus}" />
          <TextBlock FontWeight="SemiBold" Text="Current Step:" />
          <TextBlock Margin="6,0,0,0" Text="{Binding CurrentStep}" />
        </DockPanel>
        <Grid Grid.Row="3" Margin="0,10,0,10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
          </Grid.ColumnDefinitions>
          <GroupBox Grid.Column="0" Header="Step Timeline" Margin="0,0,8,0">
            <ListBox ItemsSource="{Binding StepTimeline}">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <DockPanel Margin="0,0,0,6">
                    <TextBlock Width="90" FontWeight="SemiBold" Text="{Binding Name}" />
                    <TextBlock Width="90" Opacity="0.7" Text="{Binding State}" />
                    <TextBlock Opacity="0.7" Text="{Binding Progress, StringFormat={}{0:F1}%}" />
                  </DockPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </GroupBox>
          <GroupBox Grid.Column="1" Header="Live Log">
            <ListBox ItemsSource="{Binding LiveLogs}" />
          </GroupBox>
        </Grid>

        <GroupBox Grid.Row="4" Header="Chat" Margin="0,0,0,10">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <ListBox Grid.Row="0" Margin="0,6,0,8" ItemsSource="{Binding ChatMessages}">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Margin="0,0,0,10">
                    <DockPanel>
                      <TextBlock FontWeight="SemiBold" Text="{Binding Role}" />
                      <TextBlock Margin="8,0,0,0" Opacity="0.7" Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" />
                    </DockPanel>
                    <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="{Binding Text}" />
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
            <DockPanel Grid.Row="1">
              <Button Width="90"
                      Height="32"
                      Margin="8,0,0,0"
                      Content="Send"
                      Command="{Binding SendChatCommand}"
                      DockPanel.Dock="Right" />
              <TextBox Height="32"
                       VerticalContentAlignment="Center"
                       Text="{Binding ChatInput, UpdateSourceTrigger=PropertyChanged}" />
            </DockPanel>
          </Grid>
        </GroupBox>

        <DockPanel Grid.Row="5">
          <TextBlock FontStyle="Italic" Opacity="0.7" Text="State updates are streamed over SSE in real time." />
        </DockPanel>
      </Grid>
    </Border>

    <Border Grid.Column="2" Padding="10" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Sources" />
        <ListBox Grid.Row="1" Margin="0,10,0,0" ItemsSource="{Binding Sources}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Margin="0,0,0,10" Padding="8" BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="4">
                <StackPanel>
                  <DockPanel>
                    <TextBlock FontWeight="SemiBold" Text="{Binding ChunkId}" />
                    <Button Width="115"
                            Height="24"
                            Margin="8,0,0,0"
                            Content="Copy timestamp"
                            Command="{Binding DataContext.CopyTimestampCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            DockPanel.Dock="Right" />
                  </DockPanel>
                  <TextBlock Margin="0,4,0,0" Opacity="0.65" Text="{Binding T0, StringFormat=t0: {0:F1}s}" />
                  <TextBlock Opacity="0.65" Text="{Binding T1, StringFormat=t1: {0:F1}s}" />
                  <TextBlock Margin="0,6,0,0" Opacity="0.85" TextWrapping="Wrap" Text="{Binding Snippet}" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>
  </Grid>
</Window>